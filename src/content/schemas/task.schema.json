{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task.schema.json",
  "title": "Tracker Task Definition",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "note": { "type": "string" },
    "hoverNote": { "type": "string" },
    "hover": {
      "type": "object",
      "properties": {
        "note": { "type": "string" }
      },
      "additionalProperties": true
    },
    "wiki": { "type": "string" },
    "reset": { "type": "string" },
    "cadence": { "$ref": "cadence.schema.json" }
  },
  "additionalProperties": true
}

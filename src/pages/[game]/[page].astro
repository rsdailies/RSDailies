---
export const prerender = true;
import MainLayout from '@app/layout/MainLayout.astro';
import { Dashboard, Overview } from '@features/tracker';
import { getCollection } from 'astro:content';
import { getTrackerPrimaryNavItems } from '@features/navigation';

export async function getStaticPaths() {
	return [
		{ params: { game: 'rs3', page: 'tasks' } },
		{ params: { game: 'rs3', page: 'gathering' } },
		{ params: { game: 'rs3', page: 'timers' } },
		{ params: { game: 'osrs', page: 'tasks' } },
	];
}

const game = Astro.params.game === 'osrs' ? 'osrs' : 'rs3';
const page = Astro.params.page || 'tasks';
const route = `/${game}/${page}`;
const mode = page === 'tasks' ? 'all' : page;

const pages = await getCollection('pages');
const pageEntry = pages.find((entry) => entry.data.route === route);

if (!pageEntry) {
	return Astro.redirect('/rs3/tasks');
}

const sectionEntries = await getCollection('sections', (entry) => entry.data.game === game);
const sectionById = new Map(sectionEntries.map((entry) => [entry.data.id, entry]));
const sections = pageEntry.data.sections
	.map((sectionId) => sectionById.get(sectionId))
	.filter(Boolean)
	.sort((a, b) => (a!.data.displayOrder ?? 100) - (b!.data.displayOrder ?? 100));

const allSections = sectionEntries.sort((a, b) => (a.data.displayOrder ?? 100) - (b.data.displayOrder ?? 100));
const navItems = getTrackerPrimaryNavItems(game);
const gameLabel = game === 'osrs' ? 'OSRS' : 'RS3';
const pageLabel = pageEntry.data.title || page.charAt(0).toUpperCase() + page.slice(1);
const pageHeading = page === 'tasks' ? 'Daily Tasks' : pageLabel;
const pageSubtitle = "Daily, Weekly, and Monthly Task Trackers";
const showOsrsNotice = game === 'osrs';
---

<MainLayout title={`RSDailies - ${gameLabel} ${pageLabel}`} {game} {mode} {navItems}>
	<header class="tracker-page-header">
		<p class="tracker-kicker">{game === 'osrs' ? 'Old School RuneScape' : 'RuneScape 3'}</p>
		<h1>{pageHeading}</h1>
		<p class="tracker-subtitle">{pageSubtitle}</p>
	</header>
	{showOsrsNotice && (
		<section class="tracker-route-notice" aria-label="OSRS tracker status">
			<strong>OSRS tracker is being built.</strong>
			<p>RS3 is fully available now. OSRS task data will appear here as sections are added.</p>
		</section>
	)}
	<Overview client:load {allSections} />
	<Dashboard client:load {sections} />
</MainLayout>

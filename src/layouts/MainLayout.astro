---
import 'bootstrap/dist/css/bootstrap.min.css';
import '../styles/tokens/tokens.css';
import '../styles/base/base.css';
import '../styles/base/states.css';
import '../styles/components/modal.css';
import '../styles/components/button.css';
import '../styles/components/header.css';
import '../styles/shell/index.css';
import '../styles/shell/layout.css';
import '../styles/shell/controls.css';
import '../styles/tracker/row.css';
import '../styles/tracker/column.css';
import '../styles/tracker/table.css';
import '../styles/tracker/farming.css';
import '../styles/pages/overview.css';
import '../styles/shell/responsive.css';

import { StorageKeyBuilder } from '../lib/shared/storage/keys-builder.ts';
import { initStorageService, load, save } from '../lib/shared/storage/storage-service.ts';
import Navbar from '../components/layout/Navbar.svelte';
import Footer from '../components/layout/Footer.astro';
import ModalContainer from '../components/modals/ModalContainer.svelte';

interface Props {
	title: string;
	game?: string;
	mode?: string;
	navItems?: any[];
}

const { title, game = 'rs3', mode = 'all', navItems = [] } = Astro.props;

// Initialize storage with defaults
initStorageService(load('activeProfile', 'default'));
if (!load(StorageKeyBuilder.settings(), null)) {
	save(StorageKeyBuilder.settings(), {
		splitDailyTables: true,
		splitWeeklyTables: true,
		showCompletedTasks: false,
		herbTicks: 4,
		growthOffsetMinutes: 0,
		browserNotif: false,
		overviewVisible: true,
	});
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<link rel="icon" type="image/png" href="/img/dailyscape.png" />
		<meta name="description" content="RSDailies is an Astro + Svelte RuneScape tracker for RS3 tasks, gathering, farming timers, and an intentionally empty OSRS task shell." />
	</head>
	<body id="app" data-game={game} data-mode={mode}>
		<Navbar client:load {game} {mode} {navItems} />
		<main class="container-xl activity_tables" id="dashboard-container">
			<slot />
		</main>
		<footer id="main-footer">
			<Footer />
		</footer>
		<div id="modals-mount">
			<ModalContainer client:load />
		</div>
		<div id="tooltip" style="display:none; visibility:hidden;"></div>
		<script>
			// Seed route state from URL
			const pathParts = window.location.pathname.split('/').filter(Boolean);
			const game = pathParts[0] === 'osrs' ? 'osrs' : 'rs3';
			const page = pathParts[1] || 'tasks';
			document.body.dataset.game = game;
			document.body.dataset.mode = page === 'tasks' ? 'all' : page;
		</script>
	</body>
</html>

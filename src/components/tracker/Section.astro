---
import { TrackerRow } from './TrackerRow';

interface Props {
	id: string;
	label: string;
	tasks: any[];
	game?: string;
}

const { id, label, tasks, game = 'rs3' } = Astro.props;
---

<div class="table_container" id={`${id}_container`} data-section={id}>
	<table class="activity_table tracker-table" id={`${id}_table`}>
		<thead>
			<tr class="header_like_row">
				<td colspan="3" class="header_like_color">
					<div class="header_like_inner section-panel-header">
						<div class="activity_name header_like_name section-panel-title">
							<span class="header_like_text">{label}</span>
						</div>
						<div class="header_like_controls section-panel-controls">
							{/* Status span for countdowns (populated via heartbeat) */}
							<span id={`${id}_status`} class="header_like_status countdown badge bg-secondary section-panel-countdown">--:--:--</span>
							
							<button id={`${id}_reset_button`} type="button" class="btn btn-secondary btn-sm active primitive-btn section-panel-reset-button" title="Reset section">&#267B;</button>
							<button id={`${id}_hide_button`} type="button" class="btn btn-secondary btn-sm active primitive-btn hide_button section-panel-toggle-button" title="Hide section">&#25BC;</button>
							<button id={`${id}_unhide_button`} type="button" class="btn btn-secondary btn-sm active primitive-btn unhide_button section-panel-toggle-button" title="Show section" style="display:none;">&#25B6;</button>
						</div>
					</div>
				</td>
			</tr>
		</thead>
		<tbody id={`${id}-tbody`}>
			{Array.isArray(tasks) && tasks.map(task => (
				<TrackerRow 
					client:load 
					id={task.id} 
					name={task.name} 
					wiki={task.wiki} 
					note={task.note}
					sectionKey={id}
				/>
			))}
			{(!tasks || tasks.length === 0) && (
				<tr class="empty-row">
					<td colspan="3" class="text-center text-muted small py-3">
						No tasks found in this section.
					</td>
				</tr>
			)}
		</tbody>
	</table>
</div>

<script>
	// Restore the simple Section Control bindings
	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement;
		const resetBtn = target.closest('.section-panel-reset-button');
		const hideBtn = target.closest('.hide_button');
		const unhideBtn = target.closest('.unhide_button');

		if (resetBtn) {
			const sectionId = resetBtn.id.replace('_reset_button', '');
			console.log(`[Section] Resetting ${sectionId}...`);
			// Logic to clear localStorage for this section
			window.location.reload();
		}

		if (hideBtn) {
			const container = hideBtn.closest('.table_container') as HTMLElement;
			if (container) {
				const tbody = container.querySelector('tbody');
				if (tbody) tbody.style.display = 'none';
				(hideBtn as HTMLElement).style.display = 'none';
				const unhide = container.querySelector('.unhide_button') as HTMLElement;
				if (unhide) unhide.style.display = 'inline-block';
			}
		}

		if (unhideBtn) {
			const container = unhideBtn.closest('.table_container') as HTMLElement;
			if (container) {
				const tbody = container.querySelector('tbody');
				if (tbody) tbody.style.display = 'table-row-group';
				(unhideBtn as HTMLElement).style.display = 'none';
				const hide = container.querySelector('.hide_button') as HTMLElement;
				if (hide) hide.style.display = 'inline-block';
			}
		}
	});
</script>
